{
    "dataset": "mnist",
    "epochs": 5,
    "batch_size": 64,
    "learning_rate": 0.001,
    "optimizer": "adam",
    "num_layers": 3,
    "hidden_size": [
        128,
        128,
        128
    ],
    "activation": "relu",
    "loss": "cross_entropy",
    "weight_init": "xavier",
    "weight_decay": 0,
    "model_save_path": "models/model.npy"
}