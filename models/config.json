{
    "dataset": "mnist",
    "epochs": 2,
    "batch_size": 64,
    "learning_rate": 0.001,
    "optimizer": "sgd",
    "num_layers": 3,
    "hidden_size": [
        128,
        128,
        128
    ],
    "activation": "tanh",
    "loss": "cross_entropy",
    "weight_init": "xavier",
    "weight_decay": 0.0,
    "model_path": "models/model.npy"
}